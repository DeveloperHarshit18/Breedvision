# BreedVision Backend — Environment Variables
# Copy this file to .env and fill in your values.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/breedvision

# --- Roboflow Integration (optional) ---
# Set USE_ROBOFLOW=true to use the real Roboflow API instead of mock predictions
USE_ROBOFLOW=false
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_PROJECT_URL=https://detect.roboflow.com/your-project-name/1

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1
